# Environment Configuration for tastytrade-sdk
# Copy this file to .env and fill in your actual values

# ============================================================================
# LLM API Keys
# ============================================================================
QUBER_ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-api-key
QUBER_OPENAI_API_KEY=sk-proj-your-openai-api-key

# Legacy compatibility
OPENAI_API_KEY=${QUBER_OPENAI_API_KEY}

# ============================================================================
# GitHub Integration
# ============================================================================
GH_TOKEN=gho_your-github-token
GITHUB_PERSONAL_ACCESS_TOKEN=${GH_TOKEN}

# ============================================================================
# Jira/Atlassian Configuration
# ============================================================================
ATLASSIAN_USER_EMAIL=your-email@example.com
ATLASSIAN_API_TOKEN=your-atlassian-api-token
ATLASSIAN_SITE_NAME=https://mandeng.atlassian.net

# Project-specific Jira configuration
JIRA_PROJECT_PREFIX=TT
JIRA_PROJECT_LABEL=tastytrade-sdk

# Legacy aliases (for compatibility)
JIRA_URL=${ATLASSIAN_SITE_NAME}
JIRA_USERNAME=${ATLASSIAN_USER_EMAIL}
JIRA_API_TOKEN=${ATLASSIAN_API_TOKEN}

# ============================================================================
# LangSmith Tracing (Claude Code Hook)
# ============================================================================
TRACE_TO_LANGSMITH=true
LANGSMITH_API_KEY=lsv2_pt_your-langsmith-api-key
CC_LANGSMITH_API_KEY=${LANGSMITH_API_KEY}
CC_LANGSMITH_PROJECT=tastytrade-sdk
CC_LANGSMITH_RUN_NAME=tastytrade-sdk
CC_LANGSMITH_DEBUG=false

# ============================================================================
# PyPI Publishing (if applicable)
# ============================================================================
# PYPI_TOKEN=pypi-your-production-token
# TEST_PYPI_TOKEN=pypi-your-test-token

# ============================================================================
# Notes
# ============================================================================
# 1. Never commit .env file to git (it's in .gitignore)
# 2. GitHub Actions secrets are configured separately in repository settings
# 3. For DevContainer usage, variables are loaded by startup.sh
# 4. Jira project prefix "TT" is used for issue keys (TT-XXX)
# 5. Jira project label "tastytrade-sdk" is auto-applied to all created issues
